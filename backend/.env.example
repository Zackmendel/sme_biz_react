# --- Supabase (Auth + API) ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Postgres (Alembic + direct DB access) ---
# Direct connection string (non-pooled) for migrations:
# DATABASE_URL=postgresql://postgres.your-project-id:your-db-password@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
# Transaction pooled connection string for runtime:
DATABASE_URL=postgresql://postgres.your-project-id:your-db-password@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# --- Gemini (LLM Orchestration) ---
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
# I am using gcloud ADC for this.



# --- Telegram Bot API (Reporting/Alerts) ---
TELEGRAM_BOT_TOKEN=telegram_bot_token

# --- Server ---
PORT=8000
# Comma-separated browser origins allowed to call the API (CORS).
ALLOWED_ORIGINS=http://localhost:5173
